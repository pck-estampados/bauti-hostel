# Entorno operativo. `demo` usa solamente datos ficticios en memoria.
# `production` exige Supabase y nunca carga inventario demo.
APP_MODE=demo

# URL canónica del sitio. En producción debe ser HTTPS y no terminar con `/`.
# Para pruebas locales se admite http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase > Project Settings > API / Connect.
# La clave publicable puede estar en el navegador porque el acceso real lo protege RLS.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Opcional. Solo es necesaria para tareas administrativas server-side que
# utilicen explícitamente createSupabaseAdminClient(). El login y el panel
# operativo normal funcionan con sesión autenticada + RLS y no la requieren.
# SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Alternativa heredada para operaciones administrativas server-side.
# SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_LEGACY_SERVICE_ROLE_KEY

# Tarifa pública de referencia. No representa inventario ni disponibilidad real.
