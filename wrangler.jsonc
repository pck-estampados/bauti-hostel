{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hostel-bauti",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": ["nodejs_compat"],

  "workers_dev": true,
  "preview_urls": true,
  "keep_vars": true,

  "assets": {
    "binding": "ASSETS"
  },

  "images": {
    "binding": "IMAGES"
  },

  "observability": {
    "enabled": true
  }
}
